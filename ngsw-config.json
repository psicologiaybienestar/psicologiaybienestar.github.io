{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "datasets",
      "urls": [
        "/assets/data/*.json"
      ],
      "cacheConfig": {
        "maxSize": 10,
        "maxAge": "30d",
        "timeout": "1s",
        "strategy": "performance"
      }
    }
  ],
  "navigationRequestStrategy": "freshness"
}
